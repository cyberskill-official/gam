{
    "name": "gam",
    "type": "module",
    "version": "1.0.11",
    "description": "Git Alias Manager — A professional desktop GUI for managing Git aliases",
    "author": "zintaen <zintaen@example.com>",
    "license": "MIT",
    "homepage": "https://github.com/zintaen/gam#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/zintaen/gam.git"
    },
    "bugs": {
        "url": "https://github.com/zintaen/gam/issues"
    },
    "keywords": [
        "git",
        "alias",
        "manager",
        "tauri",
        "desktop"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "ai:setup": "cyberskill ai:setup",
        "build": "dotenv -- tauri build --target universal-apple-darwin",
        "dev": "tauri dev",
        "inspect": "cyberskill inspect",
        "lint": "cyberskill lint",
        "lint:fix": "cyberskill lint:fix",
        "lint:inspect": "cyberskill lint:inspect",
        "preview": "vite preview",
        "ready": "cyberskill ready",
        "release": "node scripts/release.js",
        "reset": "cyberskill reset",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "vite": "vite",
        "vite:build": "vite build"
    },
    "dependencies": {
        "@cyberskill/shared": "3.21.0",
        "@tauri-apps/api": "2.11.1",
        "@tauri-apps/plugin-process": "2.3.1",
        "@tauri-apps/plugin-updater": "2.10.1",
        "npm-run-all2": "9.0.2",
        "react": "19.2.7",
        "react-dom": "19.2.7"
    },
    "devDependencies": {
        "@commitlint/cli": "21.0.2",
        "@commitlint/config-conventional": "21.0.2",
        "@playwright/test": "1.61.0",
        "@tailwindcss/postcss": "4.3.1",
        "@tauri-apps/cli": "2.11.3",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "26.0.0",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "@vitest/coverage-v8": "4.1.9",
        "autoprefixer": "10.5.0",
        "dotenv-cli": "11.0.0",
        "eslint": "10.5.0",
        "jsdom": "29.1.1",
        "lint-staged": "17.0.8",
        "postcss": "8.5.15",
        "puppeteer": "25.2.0",
        "simple-git-hooks": "2.13.1",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "4.1.9"
    }
}
